"name": "AI Doctor Project",
"image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
"customizations": {
  "codespaces": {
    "openFiles": [
      "README.md",
      "app.py"
    ]
  },
  "vscode": {
    "settings": {
      "python.defaultInterpreterPath": "/usr/local/bin/python",
      "python.linting.enabled": true,
      "python.linting.pylintEnabled": true,
      "python.formatting.autopepPath": "/usr/local/py-utils/bin/autopep",
      "python.formatting.provider": "autopep"
    },
    "extensions": [
      "ms-python.python",
      "ms-python.vscode-pylance",
      "ms-toolsai.jupyter",
      "GrapeCity.gc-excelviewer",
      "ms-tyriar.streamlit"
    ]
  }
},
"updateContentCommand": "sudo apt update && sudo apt upgrade -y && pip install --upgrade pip",
"postCreateCommand": "pip install -r requirements.txt",
"postAttachCommand": {
  "server": "streamlit run app.py --server.port=8501 --server.address=0.0.0.0 --server.enableCORS false --server.enableXsrfProtection false"
},
"portsAttributes": {
  "8501": {
    "label": "AI Doctor App",
    "onAutoForward": "openPreview"
  }
},
"forwardPorts": [
  8501
],
"features": {
  "ghcr.io/devcontainers/features/python:1": {
    "installTools": true,
    "version": "3.11"
  }
}
}